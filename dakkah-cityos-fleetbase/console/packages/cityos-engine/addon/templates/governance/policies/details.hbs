<Layout::Section::Header @title="Policy Detail" />
<Layout::Section::Body>
    <div class="p-6 space-y-6">
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow border border-gray-200 dark:border-gray-700">
            <div class="p-4 border-b border-gray-200 dark:border-gray-700">
                <h3 class="text-lg font-semibold text-gray-900 dark:text-white">General Information</h3>
            </div>
            <div class="p-4">
                <dl class="grid grid-cols-1 md:grid-cols-2 gap-x-6 gap-y-4">
                    <div>
                        <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Name</dt>
                        <dd class="mt-1 text-sm text-gray-900 dark:text-white">{{@model.name}}</dd>
                    </div>
                    <div>
                        <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Slug</dt>
                        <dd class="mt-1 text-sm text-gray-900 dark:text-white">{{@model.slug}}</dd>
                    </div>
                    <div>
                        <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Type</dt>
                        <dd class="mt-1 text-sm text-gray-900 dark:text-white">{{@model.type}}</dd>
                    </div>
                    <div>
                        <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Scope</dt>
                        <dd class="mt-1 text-sm text-gray-900 dark:text-white">{{@model.scope}}</dd>
                    </div>
                    <div>
                        <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Priority</dt>
                        <dd class="mt-1 text-sm text-gray-900 dark:text-white">{{@model.priority}}</dd>
                    </div>
                    <div>
                        <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Authority UUID</dt>
                        <dd class="mt-1 text-sm font-mono text-gray-900 dark:text-white">{{@model.authority_uuid}}</dd>
                    </div>
                    <div>
                        <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Region UUID</dt>
                        <dd class="mt-1 text-sm font-mono text-gray-900 dark:text-white">{{@model.region_uuid}}</dd>
                    </div>
                    <div>
                        <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Country UUID</dt>
                        <dd class="mt-1 text-sm font-mono text-gray-900 dark:text-white">{{@model.country_uuid}}</dd>
                    </div>
                    <div>
                        <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Tenant UUID</dt>
                        <dd class="mt-1 text-sm font-mono text-gray-900 dark:text-white">{{@model.tenant_uuid}}</dd>
                    </div>
                    <div>
                        <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Enforced</dt>
                        <dd class="mt-1">
                            <span class="px-2 py-1 rounded-full text-xs font-medium {{if @model.enforced "bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-200" "bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-300"}}">{{if @model.enforced "Yes" "No"}}</span>
                        </dd>
                    </div>
                    <div>
                        <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Status</dt>
                        <dd class="mt-1">
                            <span class="px-2 py-1 rounded-full text-xs font-medium {{if (eq @model.status "active") "bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200" "bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-300"}}">{{@model.status}}</span>
                        </dd>
                    </div>
                    <div>
                        <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Created At</dt>
                        <dd class="mt-1 text-sm text-gray-900 dark:text-white">{{@model.created_at}}</dd>
                    </div>
                    <div>
                        <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Updated At</dt>
                        <dd class="mt-1 text-sm text-gray-900 dark:text-white">{{@model.updated_at}}</dd>
                    </div>
                </dl>
            </div>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow border border-gray-200 dark:border-gray-700">
            <div class="p-4 border-b border-gray-200 dark:border-gray-700">
                <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Policy Data</h3>
            </div>
            <div class="p-4">
                <pre class="text-sm text-gray-900 dark:text-gray-300 bg-gray-50 dark:bg-gray-900 p-3 rounded-lg overflow-x-auto font-mono">{{@model.policy_data}}</pre>
            </div>
        </div>
    </div>
</Layout::Section::Body>
