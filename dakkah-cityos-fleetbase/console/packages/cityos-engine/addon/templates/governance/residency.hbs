<Layout::Section::Header @title="Data Residency">
    <div class="flex items-center space-x-2">
        <span class="text-sm text-gray-500 dark:text-gray-400">
            <FaIcon @icon="shield-halved" class="mr-1" />
            Governance
            <FaIcon @icon="chevron-right" class="mx-1 text-xs" />
            Residency
        </span>
    </div>
</Layout::Section::Header>

<Layout::Section::Body>
    <div class="p-6 space-y-6">
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow border border-gray-200 dark:border-gray-700 p-6">
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4 flex items-center">
                <FaIcon @icon="globe" class="mr-2 text-blue-500" />
                Data Classification by Residency
            </h3>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div class="border border-red-200 dark:border-red-800 rounded-lg overflow-hidden">
                    <div class="p-4 bg-red-50 dark:bg-red-900/20 border-b border-red-200 dark:border-red-800">
                        <div class="flex items-center">
                            <div class="w-3 h-3 rounded-full bg-red-500 mr-2"></div>
                            <h4 class="font-semibold text-red-800 dark:text-red-300">Sovereign</h4>
                        </div>
                        <p class="text-xs text-red-600 dark:text-red-400 mt-1">Must remain in-country</p>
                    </div>
                    <div class="p-4 space-y-2">
                        {{#each this.model.sovereign as |item|}}
                            <div class="flex items-center text-sm">
                                <FaIcon @icon="lock" class="mr-2 text-red-500 text-xs" />
                                <span class="text-gray-900 dark:text-white">{{item}}</span>
                            </div>
                        {{/each}}
                    </div>
                </div>

                <div class="border border-yellow-200 dark:border-yellow-800 rounded-lg overflow-hidden">
                    <div class="p-4 bg-yellow-50 dark:bg-yellow-900/20 border-b border-yellow-200 dark:border-yellow-800">
                        <div class="flex items-center">
                            <div class="w-3 h-3 rounded-full bg-yellow-500 mr-2"></div>
                            <h4 class="font-semibold text-yellow-800 dark:text-yellow-300">Regional</h4>
                        </div>
                        <p class="text-xs text-yellow-600 dark:text-yellow-400 mt-1">Restricted to MENA region</p>
                    </div>
                    <div class="p-4 space-y-2">
                        {{#each this.model.regional as |item|}}
                            <div class="flex items-center text-sm">
                                <FaIcon @icon="map" class="mr-2 text-yellow-500 text-xs" />
                                <span class="text-gray-900 dark:text-white">{{item}}</span>
                            </div>
                        {{/each}}
                    </div>
                </div>

                <div class="border border-green-200 dark:border-green-800 rounded-lg overflow-hidden">
                    <div class="p-4 bg-green-50 dark:bg-green-900/20 border-b border-green-200 dark:border-green-800">
                        <div class="flex items-center">
                            <div class="w-3 h-3 rounded-full bg-green-500 mr-2"></div>
                            <h4 class="font-semibold text-green-800 dark:text-green-300">Global</h4>
                        </div>
                        <p class="text-xs text-green-600 dark:text-green-400 mt-1">Can be processed anywhere</p>
                    </div>
                    <div class="p-4 space-y-2">
                        {{#each this.model.global as |item|}}
                            <div class="flex items-center text-sm">
                                <FaIcon @icon="earth-americas" class="mr-2 text-green-500 text-xs" />
                                <span class="text-gray-900 dark:text-white">{{item}}</span>
                            </div>
                        {{/each}}
                    </div>
                </div>
            </div>
        </div>

        <div class="bg-white dark:bg-gray-800 rounded-lg shadow border border-gray-200 dark:border-gray-700 p-6">
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4 flex items-center">
                <FaIcon @icon="server" class="mr-2 text-purple-500" />
                Processing Regions
            </h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                {{#each this.model.regions as |region|}}
                    <div class="flex items-center justify-between p-4 bg-gray-50 dark:bg-gray-750 rounded-lg">
                        <div class="flex items-center">
                            <FaIcon @icon="location-dot" class="mr-2 text-blue-500" />
                            <div>
                                <p class="text-sm font-medium text-gray-900 dark:text-white">{{region.name}}</p>
                                <p class="text-xs text-gray-500 dark:text-gray-400">{{region.location}}</p>
                            </div>
                        </div>
                        <span class="px-2 py-1 rounded-full text-xs font-medium {{if region.primary "bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200" "bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-300"}}">
                            {{if region.primary "Primary" "Secondary"}}
                        </span>
                    </div>
                {{/each}}
            </div>
        </div>
    </div>
</Layout::Section::Body>
