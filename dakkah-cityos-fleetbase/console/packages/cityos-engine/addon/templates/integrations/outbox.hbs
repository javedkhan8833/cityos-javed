<Layout::Section::Header @title="CityBus Outbox">
    <div class="flex items-center space-x-2">
        <span class="text-sm text-gray-500 dark:text-gray-400">
            <FaIcon @icon="plug" class="mr-1" />
            Integrations
            <FaIcon @icon="chevron-right" class="mx-1 text-xs" />
            Outbox
        </span>
        <Button @icon="rotate" @text="Refresh" @onClick={{this.loadAll}} @isLoading={{this.isLoading}} @type="default" @size="sm" />
    </div>
</Layout::Section::Header>

<Layout::Section::Body>
    <div class="p-6 space-y-6">
        {{#if this.isLoading}}
            <div class="flex items-center justify-center py-12">
                <FaIcon @icon="spinner" @spin={{true}} class="text-gray-400 text-2xl" />
            </div>
        {{else}}
            <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
                <div class="bg-white dark:bg-gray-800 rounded-lg shadow border border-gray-200 dark:border-gray-700 p-6 text-center">
                    <div class="p-3 bg-yellow-100 dark:bg-yellow-900 rounded-full w-12 h-12 mx-auto flex items-center justify-center mb-3">
                        <FaIcon @icon="clock" class="text-yellow-600 dark:text-yellow-300 text-lg" />
                    </div>
                    <p class="text-3xl font-bold text-gray-900 dark:text-white">{{if this.stats.pending this.stats.pending "0"}}</p>
                    <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Pending</p>
                </div>
                <div class="bg-white dark:bg-gray-800 rounded-lg shadow border border-gray-200 dark:border-gray-700 p-6 text-center">
                    <div class="p-3 bg-green-100 dark:bg-green-900 rounded-full w-12 h-12 mx-auto flex items-center justify-center mb-3">
                        <FaIcon @icon="check-circle" class="text-green-600 dark:text-green-300 text-lg" />
                    </div>
                    <p class="text-3xl font-bold text-gray-900 dark:text-white">{{if this.stats.published this.stats.published "0"}}</p>
                    <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Published</p>
                </div>
                <div class="bg-white dark:bg-gray-800 rounded-lg shadow border border-gray-200 dark:border-gray-700 p-6 text-center">
                    <div class="p-3 bg-red-100 dark:bg-red-900 rounded-full w-12 h-12 mx-auto flex items-center justify-center mb-3">
                        <FaIcon @icon="exclamation-triangle" class="text-red-600 dark:text-red-300 text-lg" />
                    </div>
                    <p class="text-3xl font-bold text-gray-900 dark:text-white">{{if this.stats.failed this.stats.failed "0"}}</p>
                    <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Failed</p>
                </div>
                <div class="bg-white dark:bg-gray-800 rounded-lg shadow border border-gray-200 dark:border-gray-700 p-6 text-center">
                    <div class="p-3 bg-gray-100 dark:bg-gray-700 rounded-full w-12 h-12 mx-auto flex items-center justify-center mb-3">
                        <FaIcon @icon="skull-crossbones" class="text-gray-600 dark:text-gray-300 text-lg" />
                    </div>
                    <p class="text-3xl font-bold text-gray-900 dark:text-white">{{if this.stats.dead_letter this.stats.dead_letter "0"}}</p>
                    <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Dead Letter</p>
                </div>
            </div>

            <div class="flex items-center space-x-4">
                <Button @icon="paper-plane" @text={{if this.isDispatching "Dispatching..." "Dispatch Pending"}} @onClick={{this.dispatchPending}} @isLoading={{this.isDispatching}} @type="primary" @size="sm" />
                {{#if this.dispatchResult}}
                    {{#if this.dispatchResult.error}}
                        <span class="text-sm text-red-600 dark:text-red-400">
                            <FaIcon @icon="exclamation-circle" class="mr-1" />
                            {{this.dispatchResult.error}}
                        </span>
                    {{else}}
                        <span class="text-sm text-green-600 dark:text-green-400">
                            <FaIcon @icon="check-circle" class="mr-1" />
                            Dispatched {{if this.dispatchResult.dispatched this.dispatchResult.dispatched "0"}} events
                        </span>
                    {{/if}}
                {{/if}}
            </div>

            <div class="bg-white dark:bg-gray-800 rounded-lg shadow border border-gray-200 dark:border-gray-700">
                <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
                    <h3 class="text-lg font-semibold text-gray-900 dark:text-white flex items-center">
                        <FaIcon @icon="list" class="mr-2 text-purple-500" />
                        Recent Events
                    </h3>
                </div>
                {{#if this.recentEvents}}
                    <div class="overflow-x-auto">
                        <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
                            <thead class="bg-gray-50 dark:bg-gray-900">
                                <tr>
                                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Event ID</th>
                                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Event Type</th>
                                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Tenant</th>
                                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Status</th>
                                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Timestamp</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
                                {{#each this.recentEvents as |event|}}
                                    <tr class="hover:bg-gray-50 dark:hover:bg-gray-750">
                                        <td class="px-4 py-3 text-sm font-mono text-gray-900 dark:text-white" title="{{event.id}}">{{if event.id (concat (slice event.id 0 8) "...") "—"}}</td>
                                        <td class="px-4 py-3 text-sm text-gray-600 dark:text-gray-300">{{event.event_type}}</td>
                                        <td class="px-4 py-3 text-sm text-gray-600 dark:text-gray-300">{{event.tenant}}</td>
                                        <td class="px-4 py-3">
                                            <span class="px-2 py-1 rounded-full text-xs font-medium
                                                {{if (eq event.status "published") "bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200"
                                                    (if (eq event.status "failed") "bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-200"
                                                        (if (eq event.status "dead_letter") "bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-200"
                                                            "bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200"))}}">
                                                {{event.status}}
                                            </span>
                                        </td>
                                        <td class="px-4 py-3 text-sm text-gray-500 dark:text-gray-400">{{event.created_at}}</td>
                                    </tr>
                                {{/each}}
                            </tbody>
                        </table>
                    </div>
                {{else}}
                    <div class="text-center py-12">
                        <FaIcon @icon="inbox" class="text-gray-400 text-3xl mb-3" />
                        <p class="text-sm text-gray-500 dark:text-gray-400">No recent events</p>
                    </div>
                {{/if}}
            </div>
        {{/if}}
    </div>
</Layout::Section::Body>
