<Layout::Section::Header @title="Temporal Workflow Console">
    <div class="flex items-center space-x-2">
        <span class="text-sm text-gray-500 dark:text-gray-400">
            <FaIcon @icon="plug" class="mr-1" />
            Integrations
            <FaIcon @icon="chevron-right" class="mx-1 text-xs" />
            Temporal
        </span>
    </div>
</Layout::Section::Header>

<Layout::Section::Body>
    <div class="p-6 space-y-6">
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow border border-gray-200 dark:border-gray-700 p-6">
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4 flex items-center">
                <FaIcon @icon="server" class="mr-2 text-blue-500" />
                Connection Status
            </h3>
            {{#if this.isLoadingConnection}}
                <div class="flex items-center justify-center py-4">
                    <FaIcon @icon="spinner" @spin={{true}} class="text-gray-400" />
                </div>
            {{else}}
                <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                    <div class="p-4 bg-gray-50 dark:bg-gray-750 rounded-lg">
                        <label class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Namespace</label>
                        <p class="text-sm font-mono text-gray-900 dark:text-white mt-1">{{if this.connection.namespace this.connection.namespace "—"}}</p>
                    </div>
                    <div class="p-4 bg-gray-50 dark:bg-gray-750 rounded-lg">
                        <label class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Address</label>
                        <p class="text-sm font-mono text-gray-900 dark:text-white mt-1">{{if this.connection.address this.connection.address "—"}}</p>
                    </div>
                    <div class="p-4 bg-gray-50 dark:bg-gray-750 rounded-lg">
                        <label class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Status</label>
                        <div class="flex items-center mt-1">
                            <div class="w-3 h-3 rounded-full {{if this.connection.configured "bg-green-500" "bg-red-500"}} mr-2"></div>
                            <span class="text-sm text-gray-900 dark:text-white">{{if this.connection.configured "Connected" "Disconnected"}}</span>
                        </div>
                    </div>
                </div>
            {{/if}}
        </div>

        <div class="flex items-center justify-between">
            <div class="flex space-x-1 bg-gray-100 dark:bg-gray-750 rounded-lg p-1">
                <button type="button" class="px-4 py-2 text-sm rounded-md {{if (eq this.activeTab 'workflows') 'bg-white dark:bg-gray-700 text-gray-900 dark:text-white shadow' 'text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white'}}" {{on "click" (fn this.setTab "workflows")}}>Workflows</button>
                <button type="button" class="px-4 py-2 text-sm rounded-md {{if (eq this.activeTab 'registry') 'bg-white dark:bg-gray-700 text-gray-900 dark:text-white shadow' 'text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white'}}" {{on "click" (fn this.setTab "registry")}}>Registry</button>
            </div>
            {{#if (eq this.activeTab "workflows")}}
                <Button @icon="rotate" @text="Refresh" @onClick={{this.loadWorkflows}} @isLoading={{this.isLoadingWorkflows}} @type="default" @size="sm" />
            {{else}}
                <Button @icon="rotate" @text="Sync Registry" @onClick={{this.triggerSync}} @isLoading={{this.isSyncing}} @type="default" @size="sm" />
            {{/if}}
        </div>

        {{#if (eq this.activeTab "workflows")}}
            <div class="bg-white dark:bg-gray-800 rounded-lg shadow border border-gray-200 dark:border-gray-700">
                {{#if this.isLoadingWorkflows}}
                    <div class="flex items-center justify-center py-12">
                        <FaIcon @icon="spinner" @spin={{true}} class="text-gray-400 text-2xl" />
                    </div>
                {{else if this.workflows.executions}}
                    <div class="overflow-x-auto">
                        <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
                            <thead class="bg-gray-50 dark:bg-gray-900">
                                <tr>
                                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Workflow ID</th>
                                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Type</th>
                                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Status</th>
                                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Start Time</th>
                                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Task Queue</th>
                                    <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Actions</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
                                {{#each this.workflows.executions as |execution|}}
                                    <tr class="hover:bg-gray-50 dark:hover:bg-gray-750 cursor-pointer" {{on "click" (fn this.viewWorkflow execution.workflow_id)}}>
                                        <td class="px-4 py-3 text-sm font-mono text-gray-900 dark:text-white">{{execution.workflow_id}}</td>
                                        <td class="px-4 py-3 text-sm text-gray-600 dark:text-gray-300">{{execution.type}}</td>
                                        <td class="px-4 py-3">
                                            <span class="px-2 py-1 rounded-full text-xs font-medium
                                                {{if (eq execution.status "RUNNING") "bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200"
                                                    (if (eq execution.status "COMPLETED") "bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200"
                                                        (if (eq execution.status "FAILED") "bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-200"
                                                            (if (eq execution.status "TERMINATED") "bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-200"
                                                                (if (eq execution.status "TIMED_OUT") "bg-orange-100 text-orange-800 dark:bg-orange-900 dark:text-orange-200"
                                                                    (if (eq execution.status "CANCELLED") "bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200"
                                                                        "bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-200")))))}}">
                                                {{execution.status}}
                                            </span>
                                        </td>
                                        <td class="px-4 py-3 text-sm text-gray-500 dark:text-gray-400">{{execution.start_time}}</td>
                                        <td class="px-4 py-3 text-sm text-gray-600 dark:text-gray-300">{{execution.task_queue}}</td>
                                        <td class="px-4 py-3 text-right">
                                            {{#if (eq execution.status "RUNNING")}}
                                                <Button @icon="stop" @text="Terminate" @onClick={{fn this.terminateWorkflow execution.workflow_id}} @type="danger" @size="xs" />
                                            {{/if}}
                                        </td>
                                    </tr>
                                {{/each}}
                            </tbody>
                        </table>
                    </div>
                {{else}}
                    <div class="text-center py-12">
                        <FaIcon @icon="inbox" class="text-gray-400 text-3xl mb-3" />
                        <p class="text-sm text-gray-500 dark:text-gray-400">No workflow executions found</p>
                    </div>
                {{/if}}
            </div>
        {{/if}}

        {{#if (eq this.activeTab "registry")}}
            {{#if this.registryStats}}
                <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                    <div class="bg-white dark:bg-gray-800 rounded-lg shadow border border-gray-200 dark:border-gray-700 p-4 text-center">
                        <p class="text-2xl font-bold text-gray-900 dark:text-white">{{if this.registryStats.total_types this.registryStats.total_types "0"}}</p>
                        <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Total Types</p>
                    </div>
                    <div class="bg-white dark:bg-gray-800 rounded-lg shadow border border-gray-200 dark:border-gray-700 p-4 text-center">
                        <p class="text-2xl font-bold text-gray-900 dark:text-white">{{if this.registryStats.active_count this.registryStats.active_count "0"}}</p>
                        <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Active</p>
                    </div>
                    <div class="bg-white dark:bg-gray-800 rounded-lg shadow border border-gray-200 dark:border-gray-700 p-4 text-center">
                        <p class="text-2xl font-bold text-gray-900 dark:text-white">{{if this.registryStats.total_executions this.registryStats.total_executions "0"}}</p>
                        <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Total Executions</p>
                    </div>
                </div>
            {{/if}}

            <div class="bg-white dark:bg-gray-800 rounded-lg shadow border border-gray-200 dark:border-gray-700">
                {{#if this.isLoadingRegistry}}
                    <div class="flex items-center justify-center py-12">
                        <FaIcon @icon="spinner" @spin={{true}} class="text-gray-400 text-2xl" />
                    </div>
                {{else if this.registry.data}}
                    <div class="overflow-x-auto">
                        <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
                            <thead class="bg-gray-50 dark:bg-gray-900">
                                <tr>
                                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Workflow Type</th>
                                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Display Name</th>
                                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Domain Pack</th>
                                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Task Queues</th>
                                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Executions</th>
                                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Status</th>
                                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Tags</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
                                {{#each this.registry.data as |entry|}}
                                    <tr class="hover:bg-gray-50 dark:hover:bg-gray-750">
                                        <td class="px-4 py-3 text-sm font-mono text-gray-900 dark:text-white">{{entry.workflow_type}}</td>
                                        <td class="px-4 py-3 text-sm text-gray-600 dark:text-gray-300">{{entry.display_name}}</td>
                                        <td class="px-4 py-3 text-sm text-gray-600 dark:text-gray-300">{{entry.domain_pack}}</td>
                                        <td class="px-4 py-3 text-sm text-gray-600 dark:text-gray-300">{{entry.task_queues}}</td>
                                        <td class="px-4 py-3 text-sm text-gray-900 dark:text-white font-semibold">{{entry.execution_count}}</td>
                                        <td class="px-4 py-3">
                                            <span class="px-2 py-1 rounded-full text-xs font-medium {{if (eq entry.status "active") "bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200" "bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-200"}}">{{entry.status}}</span>
                                        </td>
                                        <td class="px-4 py-3 text-sm text-gray-500 dark:text-gray-400">{{entry.tags}}</td>
                                    </tr>
                                {{/each}}
                            </tbody>
                        </table>
                    </div>
                {{else}}
                    <div class="text-center py-12">
                        <FaIcon @icon="inbox" class="text-gray-400 text-3xl mb-3" />
                        <p class="text-sm text-gray-500 dark:text-gray-400">No registry entries found</p>
                    </div>
                {{/if}}
            </div>
        {{/if}}

        {{#if this.selectedWorkflow}}
            <div class="fixed inset-0 bg-black bg-opacity-50 z-40 flex items-center justify-center" {{on "click" this.closeDetail}}>
                <div class="bg-white dark:bg-gray-800 rounded-lg shadow-xl border border-gray-200 dark:border-gray-700 w-full max-w-2xl max-h-[80vh] overflow-y-auto m-4" {{on "click" (fn (mut this._noop) true)}}>
                    <div class="flex items-center justify-between p-6 border-b border-gray-200 dark:border-gray-700">
                        <h3 class="text-lg font-semibold text-gray-900 dark:text-white flex items-center">
                            <FaIcon @icon="diagram-project" class="mr-2 text-blue-500" />
                            Workflow Detail
                        </h3>
                        <button type="button" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-200" {{on "click" this.closeDetail}}>
                            <FaIcon @icon="times" />
                        </button>
                    </div>
                    <div class="p-6">
                        {{#if this.isLoadingDetail}}
                            <div class="flex items-center justify-center py-8">
                                <FaIcon @icon="spinner" @spin={{true}} class="text-gray-400 text-2xl" />
                            </div>
                        {{else if this.workflowDetail}}
                            <div class="space-y-4">
                                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                    <div class="p-3 bg-gray-50 dark:bg-gray-750 rounded-lg">
                                        <label class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Workflow ID</label>
                                        <p class="text-sm font-mono text-gray-900 dark:text-white mt-1">{{this.workflowDetail.workflow_id}}</p>
                                    </div>
                                    <div class="p-3 bg-gray-50 dark:bg-gray-750 rounded-lg">
                                        <label class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Run ID</label>
                                        <p class="text-sm font-mono text-gray-900 dark:text-white mt-1">{{this.workflowDetail.run_id}}</p>
                                    </div>
                                    <div class="p-3 bg-gray-50 dark:bg-gray-750 rounded-lg">
                                        <label class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Type</label>
                                        <p class="text-sm text-gray-900 dark:text-white mt-1">{{this.workflowDetail.type}}</p>
                                    </div>
                                    <div class="p-3 bg-gray-50 dark:bg-gray-750 rounded-lg">
                                        <label class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Status</label>
                                        <p class="text-sm text-gray-900 dark:text-white mt-1">{{this.workflowDetail.status}}</p>
                                    </div>
                                    <div class="p-3 bg-gray-50 dark:bg-gray-750 rounded-lg">
                                        <label class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Task Queue</label>
                                        <p class="text-sm text-gray-900 dark:text-white mt-1">{{this.workflowDetail.task_queue}}</p>
                                    </div>
                                    <div class="p-3 bg-gray-50 dark:bg-gray-750 rounded-lg">
                                        <label class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Start Time</label>
                                        <p class="text-sm text-gray-900 dark:text-white mt-1">{{this.workflowDetail.start_time}}</p>
                                    </div>
                                    <div class="p-3 bg-gray-50 dark:bg-gray-750 rounded-lg">
                                        <label class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Close Time</label>
                                        <p class="text-sm text-gray-900 dark:text-white mt-1">{{if this.workflowDetail.close_time this.workflowDetail.close_time "—"}}</p>
                                    </div>
                                    <div class="p-3 bg-gray-50 dark:bg-gray-750 rounded-lg">
                                        <label class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">History Length</label>
                                        <p class="text-sm text-gray-900 dark:text-white mt-1">{{if this.workflowDetail.history_length this.workflowDetail.history_length "—"}}</p>
                                    </div>
                                </div>
                            </div>
                        {{else}}
                            <p class="text-sm text-gray-500 dark:text-gray-400 text-center py-4">Unable to load workflow details</p>
                        {{/if}}
                    </div>
                </div>
            </div>
        {{/if}}

        {{#if this.error}}
            <div class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg p-4">
                <div class="flex items-center">
                    <FaIcon @icon="exclamation-circle" class="text-red-500 mr-2" />
                    <p class="text-sm text-red-800 dark:text-red-200">{{this.error}}</p>
                </div>
            </div>
        {{/if}}
    </div>
</Layout::Section::Body>
