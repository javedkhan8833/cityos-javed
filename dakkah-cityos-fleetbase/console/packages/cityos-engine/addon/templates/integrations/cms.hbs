<Layout::Section::Header @title="Payload CMS Integration">
    <div class="flex items-center space-x-2">
        <span class="text-sm text-gray-500 dark:text-gray-400">
            <FaIcon @icon="plug" class="mr-1" />
            Integrations
            <FaIcon @icon="chevron-right" class="mx-1 text-xs" />
            CMS
        </span>
        <Button @icon="rotate" @text="Refresh" @onClick={{this.loadAll}} @isLoading={{this.isLoading}} @type="default" @size="sm" />
    </div>
</Layout::Section::Header>

<Layout::Section::Body>
    <div class="p-6 space-y-6">
        {{#if this.isLoading}}
            <div class="flex items-center justify-center py-12">
                <FaIcon @icon="spinner" @spin={{true}} class="text-gray-400 text-2xl" />
            </div>
        {{else}}
            <div class="bg-white dark:bg-gray-800 rounded-lg shadow border border-gray-200 dark:border-gray-700 p-6">
                <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4 flex items-center">
                    <FaIcon @icon="heartbeat" class="mr-2 text-green-500" />
                    Health Status
                </h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div class="p-4 bg-gray-50 dark:bg-gray-750 rounded-lg">
                        <label class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Connection</label>
                        <div class="flex items-center mt-1">
                            <div class="w-3 h-3 rounded-full {{if this.health.connected "bg-green-500" "bg-red-500"}} mr-2"></div>
                            <span class="text-sm text-gray-900 dark:text-white">{{if this.health.connected "Connected" "Disconnected"}}</span>
                        </div>
                    </div>
                    <div class="p-4 bg-gray-50 dark:bg-gray-750 rounded-lg">
                        <label class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Version</label>
                        <p class="text-sm text-gray-900 dark:text-white mt-1">{{if this.health.version this.health.version "—"}}</p>
                    </div>
                </div>
            </div>

            <div class="bg-white dark:bg-gray-800 rounded-lg shadow border border-gray-200 dark:border-gray-700 p-6">
                <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4 flex items-center">
                    <FaIcon @icon="hard-drive" class="mr-2 text-purple-500" />
                    Storage
                </h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div class="p-4 bg-gray-50 dark:bg-gray-750 rounded-lg">
                        <label class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Provider</label>
                        <p class="text-sm text-gray-900 dark:text-white mt-1">{{if this.storage.provider this.storage.provider "—"}}</p>
                    </div>
                    <div class="p-4 bg-gray-50 dark:bg-gray-750 rounded-lg">
                        <label class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Bucket</label>
                        <p class="text-sm font-mono text-gray-900 dark:text-white mt-1">{{if this.storage.bucket this.storage.bucket "—"}}</p>
                    </div>
                </div>
            </div>

            <div class="bg-white dark:bg-gray-800 rounded-lg shadow border border-gray-200 dark:border-gray-700 p-6">
                <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4 flex items-center">
                    <FaIcon @icon="layer-group" class="mr-2 text-blue-500" />
                    Collections
                </h3>
                {{#if this.collections.collections}}
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                        {{#each this.collections.collections as |collection|}}
                            <div class="p-4 bg-gray-50 dark:bg-gray-750 rounded-lg">
                                <div class="flex items-center justify-between">
                                    <span class="text-sm font-medium text-gray-900 dark:text-white">{{collection.name}}</span>
                                    <span class="px-2 py-1 rounded-full text-xs font-medium bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200">{{collection.count}}</span>
                                </div>
                                {{#if collection.slug}}
                                    <p class="text-xs font-mono text-gray-500 dark:text-gray-400 mt-1">{{collection.slug}}</p>
                                {{/if}}
                            </div>
                        {{/each}}
                    </div>
                {{else}}
                    <p class="text-sm text-gray-500 dark:text-gray-400 text-center py-4">No collections found</p>
                {{/if}}
            </div>
        {{/if}}
    </div>
</Layout::Section::Body>
