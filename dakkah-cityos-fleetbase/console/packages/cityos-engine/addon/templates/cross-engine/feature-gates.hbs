<Layout::Section::Header @title="Feature Gates">
    <div class="flex items-center space-x-3">
        <LinkTo @route="console.cityos.cross-engine" class="text-sm text-blue-500 hover:text-blue-700"><FaIcon @icon="arrow-left" class="mr-1" />Back</LinkTo>
        <ContextSelector />
        <Button @icon="sync" @text="Refresh" @onClick={{this.loadFeatureGates}} @size="sm" @type="default" />
    </div>
</Layout::Section::Header>

<Layout::Section::Body>
    <div class="p-6 space-y-6">
        {{#if this.toggleMessage}}
            <div class="bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-lg p-3 flex items-center justify-between">
                <div class="flex items-center">
                    <FaIcon @icon="info-circle" class="text-blue-500 mr-2" />
                    <span class="text-sm text-blue-800 dark:text-blue-200">{{this.toggleMessage}}</span>
                </div>
            </div>
        {{/if}}

        <div class="bg-white dark:bg-gray-800 rounded-lg shadow border border-gray-200 dark:border-gray-700 p-6">
            <div class="flex items-center justify-between mb-4">
                <h3 class="text-lg font-semibold text-gray-900 dark:text-white flex items-center">
                    <FaIcon @icon="toggle-on" class="mr-2 text-green-500" />
                    Feature Gate Matrix
                </h3>
                <div class="flex items-center space-x-2">
                    <span class="text-xs text-gray-500 dark:text-gray-400">Features control what each tenant tier can access across all engines</span>
                </div>
            </div>

            <div class="mb-4 flex items-center space-x-4">
                <div class="flex items-center space-x-2">
                    <span class="w-3 h-3 rounded-full bg-green-500 inline-block"></span>
                    <span class="text-xs text-gray-500 dark:text-gray-400">Enabled</span>
                </div>
                <div class="flex items-center space-x-2">
                    <span class="w-3 h-3 rounded-full bg-red-500 inline-block"></span>
                    <span class="text-xs text-gray-500 dark:text-gray-400">Disabled</span>
                </div>
                <div class="flex items-center space-x-2">
                    <span class="w-3 h-3 rounded-full bg-gray-300 dark:bg-gray-600 inline-block"></span>
                    <span class="text-xs text-gray-500 dark:text-gray-400">Not Configured</span>
                </div>
            </div>

            {{#if this.isLoading}}
                <div class="flex items-center justify-center py-12">
                    <FaIcon @icon="spinner" @spin={{true}} class="text-gray-400 text-2xl" />
                </div>
            {{else}}
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
                        <thead class="bg-gray-50 dark:bg-gray-900">
                            <tr>
                                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider w-64">Feature</th>
                                {{#each this.tiers as |tier|}}
                                    <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">{{tier}}</th>
                                {{/each}}
                            </tr>
                        </thead>
                        <tbody class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
                            {{#each this.matrixRows as |row|}}
                                <tr class="hover:bg-gray-50 dark:hover:bg-gray-750 transition-colors">
                                    <td class="px-4 py-3">
                                        <div class="flex items-center">
                                            <FaIcon @icon="flag" class="mr-2 text-orange-500 text-xs" />
                                            <div>
                                                <p class="text-sm font-medium text-gray-900 dark:text-white">{{row.name}}</p>
                                                <p class="text-xs font-mono text-gray-500 dark:text-gray-400">{{row.key}}</p>
                                            </div>
                                        </div>
                                    </td>
                                    {{#each this.tiers as |tier|}}
                                        <td class="px-4 py-3 text-center">
                                            <button type="button" class="inline-flex items-center justify-center w-8 h-8 rounded-lg transition-colors hover:bg-gray-100 dark:hover:bg-gray-700" {{on "click" (fn this.toggleGate row.key tier)}}>
                                                {{#if (get row.tierStates tier)}}
                                                    <FaIcon @icon="circle-check" class="text-green-500 text-lg" />
                                                {{else}}
                                                    <FaIcon @icon="circle-xmark" class="text-red-400 text-lg" />
                                                {{/if}}
                                            </button>
                                        </td>
                                    {{/each}}
                                </tr>
                            {{else}}
                                <tr>
                                    <td colspan="6" class="px-6 py-12 text-center text-gray-500 dark:text-gray-400">
                                        <FaIcon @icon="toggle-off" class="text-3xl mb-2 text-gray-300 dark:text-gray-600" />
                                        <p>No feature gates configured</p>
                                        <p class="text-xs mt-1">Feature gates are managed via the governance policies and feature flags.</p>
                                    </td>
                                </tr>
                            {{/each}}
                        </tbody>
                    </table>
                </div>
            {{/if}}
        </div>

        {{#if (gt this.featureGroups.length 0)}}
            <div class="bg-white dark:bg-gray-800 rounded-lg shadow border border-gray-200 dark:border-gray-700 p-6">
                <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4 flex items-center">
                    <FaIcon @icon="layer-group" class="mr-2 text-purple-500" />
                    Features by Module
                </h3>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                    {{#each this.featureGroups as |group|}}
                        <div class="border border-gray-200 dark:border-gray-700 rounded-lg p-4">
                            <h4 class="text-sm font-semibold text-gray-900 dark:text-white mb-3 uppercase flex items-center">
                                <FaIcon @icon="cube" class="mr-2 text-blue-500" />
                                {{group.name}}
                            </h4>
                            <div class="space-y-2">
                                {{#each group.flags as |flag|}}
                                    <div class="flex items-center justify-between py-1.5 px-2 rounded {{if flag.enabled 'bg-green-50 dark:bg-green-900/10' 'bg-gray-50 dark:bg-gray-750'}}">
                                        <span class="text-xs font-medium text-gray-700 dark:text-gray-300 truncate">{{flag.name}}</span>
                                        <span class="ml-2 flex-shrink-0">
                                            {{#if flag.enabled}}
                                                <FaIcon @icon="circle-check" class="text-green-500" />
                                            {{else}}
                                                <FaIcon @icon="circle-xmark" class="text-red-400" />
                                            {{/if}}
                                        </span>
                                    </div>
                                {{/each}}
                            </div>
                        </div>
                    {{/each}}
                </div>
            </div>
        {{/if}}
    </div>
</Layout::Section::Body>
