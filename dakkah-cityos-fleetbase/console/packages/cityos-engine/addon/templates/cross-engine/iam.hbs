<Layout::Section::Header @title="IAM Context Integration">
    <div class="flex items-center space-x-2">
        <LinkTo @route="console.cityos.cross-engine" class="text-sm text-blue-500 hover:text-blue-700"><FaIcon @icon="arrow-left" class="mr-1" />Back to Integration Hub</LinkTo>
    </div>
</Layout::Section::Header>

<Layout::Section::Body>
    <div class="p-6 space-y-6">
        {{#if this.hasContext}}
            <div class="bg-white dark:bg-gray-800 rounded-lg shadow border border-gray-200 dark:border-gray-700 p-6">
                <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-3 flex items-center">
                    <FaIcon @icon="sitemap" class="mr-2 text-red-500" />
                    Active Context
                </h3>
                <div class="flex items-center flex-wrap gap-2">
                    {{#each this.nodeContext.contextBreadcrumb as |item index|}}
                        {{#if index}}
                            <FaIcon @icon="chevron-right" class="text-gray-400 text-xs" />
                        {{/if}}
                        <span class="inline-flex items-center px-3 py-1.5 rounded-full text-sm font-medium {{item.badgeClass}}">
                            <FaIcon @icon={{item.icon}} class="mr-1.5" />
                            {{item.name}}
                        </span>
                    {{/each}}
                </div>
            </div>
        {{else}}
            <div class="bg-yellow-50 dark:bg-yellow-900/20 border border-yellow-200 dark:border-yellow-800 rounded-lg p-4 flex items-center">
                <FaIcon @icon="info-circle" class="text-yellow-500 mr-3 text-lg" />
                <div>
                    <p class="text-sm font-medium text-yellow-800 dark:text-yellow-200">Context scoping is inactive</p>
                    <p class="text-xs text-yellow-600 dark:text-yellow-400 mt-0.5">Set a tenant context to see how IAM operations will be scoped.</p>
                </div>
            </div>
        {{/if}}

        <div class="bg-white dark:bg-gray-800 rounded-lg shadow border border-gray-200 dark:border-gray-700 p-6">
            <h3 class="text-sm font-semibold text-gray-900 dark:text-white mb-4 flex items-center">
                <FaIcon @icon="diagram-project" class="mr-2 text-red-500" />
                Permission Cascade Model
            </h3>
            <div class="flex items-center justify-center space-x-3 py-4">
                <div class="text-center">
                    <div class="w-16 h-16 rounded-full bg-blue-100 dark:bg-blue-900 flex items-center justify-center mx-auto">
                        <FaIcon @icon="globe" class="text-blue-600 dark:text-blue-400 text-xl" />
                    </div>
                    <p class="text-xs font-medium text-gray-900 dark:text-white mt-2">Country Policy</p>
                </div>
                <div class="text-center">
                    <FaIcon @icon="arrow-right" class="text-gray-400" />
                    <p class="text-xs text-gray-500 dark:text-gray-400">restricts</p>
                </div>
                <div class="text-center">
                    <div class="w-16 h-16 rounded-full bg-green-100 dark:bg-green-900 flex items-center justify-center mx-auto">
                        <FaIcon @icon="city" class="text-green-600 dark:text-green-400 text-xl" />
                    </div>
                    <p class="text-xs font-medium text-gray-900 dark:text-white mt-2">City Policy</p>
                </div>
                <div class="text-center">
                    <FaIcon @icon="arrow-right" class="text-gray-400" />
                    <p class="text-xs text-gray-500 dark:text-gray-400">restricts</p>
                </div>
                <div class="text-center">
                    <div class="w-16 h-16 rounded-full bg-purple-100 dark:bg-purple-900 flex items-center justify-center mx-auto">
                        <FaIcon @icon="building" class="text-purple-600 dark:text-purple-400 text-xl" />
                    </div>
                    <p class="text-xs font-medium text-gray-900 dark:text-white mt-2">Tenant Policy</p>
                </div>
            </div>
            <p class="text-xs text-gray-500 dark:text-gray-400 text-center">Each level can only restrict access, never expand it beyond the parent level.</p>
        </div>

        <div>
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4 flex items-center">
                <FaIcon @icon="shield-halved" class="mr-2 text-red-500" />
                Operation Scoping Rules
            </h3>
            {{#if this.isLoading}}
                <div class="flex items-center justify-center py-12">
                    <FaIcon @icon="spinner" @spin={{true}} class="text-gray-400 text-2xl" />
                </div>
            {{else}}
                <div class="space-y-4">
                    {{#each this.operationScopes as |scope|}}
                        <div class="bg-white dark:bg-gray-800 rounded-lg shadow border border-gray-200 dark:border-gray-700 border-l-4 border-l-red-500 p-5">
                            <div class="flex items-start justify-between">
                                <div class="flex items-center">
                                    <div class="w-8 h-8 rounded-lg bg-red-100 dark:bg-red-900 flex items-center justify-center mr-3">
                                        <FaIcon @icon={{scope.icon}} class="text-red-600 dark:text-red-400 text-sm" />
                                    </div>
                                    <div>
                                        <h4 class="text-sm font-semibold text-gray-900 dark:text-white">{{scope.entity}}</h4>
                                        <p class="text-xs text-gray-500 dark:text-gray-400">{{scope.scope}}</p>
                                    </div>
                                </div>
                            </div>
                            <p class="text-sm text-gray-600 dark:text-gray-300 mt-3">{{scope.description}}</p>
                            <div class="mt-3">
                                <label class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Affected Fields</label>
                                <div class="flex flex-wrap gap-1.5 mt-1">
                                    {{#each scope.fields as |field|}}
                                        <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-mono font-medium bg-gray-100 text-gray-700 dark:bg-gray-700 dark:text-gray-300">{{field}}</span>
                                    {{/each}}
                                </div>
                            </div>
                        </div>
                    {{/each}}
                </div>
            {{/if}}
        </div>

        <div class="bg-white dark:bg-gray-800 rounded-lg shadow border border-gray-200 dark:border-gray-700 p-6">
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4 flex items-center">
                <FaIcon @icon="code" class="mr-2 text-green-500" />
                Context Headers
            </h3>
            <p class="text-sm text-gray-500 dark:text-gray-400 mb-4">These X-CityOS-* headers will be sent with IAM API requests when context is active.</p>
            {{#if this.hasContext}}
                <div class="space-y-2">
                    {{#each-in this.contextHeaders as |key value|}}
                        <div class="flex items-center justify-between p-3 bg-gray-50 dark:bg-gray-750 rounded-lg">
                            <span class="text-sm font-mono text-gray-900 dark:text-white">{{key}}</span>
                            <span class="text-sm font-mono text-green-600 dark:text-green-400">{{value}}</span>
                        </div>
                    {{/each-in}}
                </div>
            {{else}}
                <div class="text-center py-6">
                    <FaIcon @icon="unlink" class="text-gray-400 text-2xl mb-2" />
                    <p class="text-sm text-gray-500 dark:text-gray-400">No context headers active</p>
                </div>
            {{/if}}
        </div>
    </div>
</Layout::Section::Body>
