<Layout::Section::Header @title="Event Bridge Monitor">
    <div class="flex items-center space-x-3">
        <LinkTo @route="console.cityos.cross-engine" class="text-sm text-blue-500 hover:text-blue-700"><FaIcon @icon="arrow-left" class="mr-1" />Back</LinkTo>
        <ContextSelector />
        <Button @icon="sync" @text="Refresh" @onClick={{this.refreshEvents}} @size="sm" @type="default" />
        <button type="button" class="px-3 py-1.5 text-sm rounded-lg transition-colors {{if this.autoRefresh 'bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-300' 'bg-gray-100 text-gray-600 dark:bg-gray-700 dark:text-gray-400'}}" {{on "click" this.toggleAutoRefresh}}>
            <FaIcon @icon={{if this.autoRefresh "pause" "play"}} class="mr-1" />
            {{if this.autoRefresh "Live" "Auto"}}
        </button>
    </div>
</Layout::Section::Header>

<Layout::Section::Body>
    <div class="p-6 space-y-6">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
            <div class="bg-white dark:bg-gray-800 rounded-lg shadow border border-gray-200 dark:border-gray-700 p-5">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-sm font-medium text-gray-500 dark:text-gray-400">Pending</p>
                        <p class="text-2xl font-bold text-yellow-600 dark:text-yellow-400">{{this.pendingCount}}</p>
                    </div>
                    <div class="p-3 bg-yellow-100 dark:bg-yellow-900 rounded-full">
                        <FaIcon @icon="clock" class="text-yellow-600 dark:text-yellow-300" />
                    </div>
                </div>
            </div>
            <div class="bg-white dark:bg-gray-800 rounded-lg shadow border border-gray-200 dark:border-gray-700 p-5">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-sm font-medium text-gray-500 dark:text-gray-400">Published</p>
                        <p class="text-2xl font-bold text-green-600 dark:text-green-400">{{this.publishedCount}}</p>
                    </div>
                    <div class="p-3 bg-green-100 dark:bg-green-900 rounded-full">
                        <FaIcon @icon="check-circle" class="text-green-600 dark:text-green-300" />
                    </div>
                </div>
            </div>
            <div class="bg-white dark:bg-gray-800 rounded-lg shadow border border-gray-200 dark:border-gray-700 p-5">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-sm font-medium text-gray-500 dark:text-gray-400">Failed</p>
                        <p class="text-2xl font-bold text-red-600 dark:text-red-400">{{this.failedCount}}</p>
                    </div>
                    <div class="p-3 bg-red-100 dark:bg-red-900 rounded-full">
                        <FaIcon @icon="exclamation-circle" class="text-red-600 dark:text-red-300" />
                    </div>
                </div>
            </div>
            <div class="bg-white dark:bg-gray-800 rounded-lg shadow border border-gray-200 dark:border-gray-700 p-5">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-sm font-medium text-gray-500 dark:text-gray-400">Dead Letter</p>
                        <p class="text-2xl font-bold text-gray-600 dark:text-gray-400">{{this.deadLetterCount}}</p>
                    </div>
                    <div class="p-3 bg-gray-100 dark:bg-gray-900 rounded-full">
                        <FaIcon @icon="skull-crossbones" class="text-gray-600 dark:text-gray-300" />
                    </div>
                </div>
            </div>
        </div>

        <div class="bg-white dark:bg-gray-800 rounded-lg shadow border border-gray-200 dark:border-gray-700">
            <div class="p-4 border-b border-gray-200 dark:border-gray-700 flex items-center justify-between flex-wrap gap-3">
                <h3 class="text-lg font-semibold text-gray-900 dark:text-white flex items-center">
                    <FaIcon @icon="stream" class="mr-2 text-blue-500" />
                    Event Stream
                    {{#if this.autoRefresh}}
                        <span class="ml-2 inline-flex items-center px-2 py-0.5 rounded-full text-xs bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-300">
                            <span class="w-1.5 h-1.5 bg-green-500 rounded-full mr-1 animate-pulse"></span>LIVE
                        </span>
                    {{/if}}
                </h3>
                <div class="flex items-center space-x-3">
                    <select class="px-2 py-1.5 text-sm bg-white dark:bg-gray-900 border border-gray-300 dark:border-gray-600 rounded text-gray-900 dark:text-white" {{on "change" this.setModuleFilter}}>
                        {{#each this.moduleOptions as |opt|}}
                            <option value={{opt}} selected={{if (eq this.selectedModule opt) true false}}>{{if (eq opt "all") "All Modules" opt}}</option>
                        {{/each}}
                    </select>
                    <select class="px-2 py-1.5 text-sm bg-white dark:bg-gray-900 border border-gray-300 dark:border-gray-600 rounded text-gray-900 dark:text-white" {{on "change" this.setStatusFilter}}>
                        {{#each this.statusOptions as |opt|}}
                            <option value={{opt}} selected={{if (eq this.selectedStatus opt) true false}}>{{if (eq opt "all") "All Statuses" opt}}</option>
                        {{/each}}
                    </select>
                </div>
            </div>

            {{#if this.isLoading}}
                <div class="flex items-center justify-center py-12">
                    <FaIcon @icon="spinner" @spin={{true}} class="text-gray-400 text-2xl" />
                </div>
            {{else}}
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
                        <thead class="bg-gray-50 dark:bg-gray-900">
                            <tr>
                                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Event Type</th>
                                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Module</th>
                                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Tenant</th>
                                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Status</th>
                                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Correlation ID</th>
                                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Time</th>
                            </tr>
                        </thead>
                        <tbody class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
                            {{#each this.filteredEvents as |event|}}
                                <tr class="hover:bg-gray-50 dark:hover:bg-gray-750 transition-colors">
                                    <td class="px-4 py-3">
                                        <span class="px-2 py-1 bg-blue-100 dark:bg-blue-900 text-blue-800 dark:text-blue-200 rounded text-xs font-mono">{{event.event_type}}</span>
                                    </td>
                                    <td class="px-4 py-3">
                                        <span class="text-sm text-gray-700 dark:text-gray-300">{{if event.payload.source.module event.payload.source.module "—"}}</span>
                                    </td>
                                    <td class="px-4 py-3">
                                        <span class="text-sm text-gray-700 dark:text-gray-300">{{if event.tenant_id event.tenant_id "—"}}</span>
                                    </td>
                                    <td class="px-4 py-3">
                                        <span class="px-2 py-0.5 rounded-full text-xs font-medium
                                            {{if (eq event.status "published") "bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200"
                                            (if (eq event.status "pending") "bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200"
                                            (if (eq event.status "failed") "bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-200"
                                            "bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-300"))}}">
                                            {{event.status}}
                                        </span>
                                    </td>
                                    <td class="px-4 py-3">
                                        <span class="text-xs font-mono text-gray-500 dark:text-gray-400" title={{event.correlation_id}}>{{if event.correlation_id event.correlation_id "—"}}</span>
                                    </td>
                                    <td class="px-4 py-3">
                                        <span class="text-xs text-gray-500 dark:text-gray-400">{{event.created_at}}</span>
                                    </td>
                                </tr>
                            {{else}}
                                <tr>
                                    <td colspan="6" class="px-6 py-12 text-center text-gray-500 dark:text-gray-400">
                                        <FaIcon @icon="stream" class="text-3xl mb-2 text-gray-300 dark:text-gray-600" />
                                        <p>No events in the bridge</p>
                                        <p class="text-xs mt-1">Events appear here when the CityBus event bridge is enabled (CITYOS_EVENT_BRIDGE_ENABLED=true).</p>
                                    </td>
                                </tr>
                            {{/each}}
                        </tbody>
                    </table>
                </div>
            {{/if}}
        </div>
    </div>
</Layout::Section::Body>
