modules = ["php-8.2", "bash", "python-3.11", "nodejs-20", "postgresql-16"]
[agent]
expertMode = true
integrations = ["github:1.0.0", "twilio:1.0.0"]

[nix]
channel = "stable-25_05"
packages = ["mariadb", "php82Extensions.grpc", "php82Extensions.protobuf", "protobuf"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "API Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Console Frontend"

[[workflows.workflow]]
name = "API Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd /home/runner/workspace/api && php -d memory_limit=512M -S 0.0.0.0:8000 -t public server.php"
waitForPort = 8000

[[workflows.workflow]]
name = "Console Frontend"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd /home/runner/workspace/console && npx ember serve --port 5000 --host 0.0.0.0 --proxy http://localhost:8000 --environment development 2>&1"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3000

[[ports]]
localPort = 8000
externalPort = 8000

[deployment]
deploymentTarget = "vm"
run = ["bash", "deploy-run.sh"]
build = ["bash", "deploy-build.sh"]

[userenv]

[userenv.shared]
EXTENSIONS = "@fleetbase/cityos-engine"
API_PORT = "8000"
CONSOLE_PORT = "5000"
CITYOS_SCOPING_ENABLED = "true"
